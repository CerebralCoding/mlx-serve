<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Hardened Runtime resource access: required to use the microphone in
	     Voice mode. Without this entitlement macOS denies mic access under the
	     hardened runtime and never shows the TCC permission prompt. The
	     NSMicrophoneUsageDescription string in Info.plist only supplies the
	     prompt text; this is what actually unlocks the capability. -->
	<key>com.apple.security.device.audio-input</key>
	<true/>

	<!-- Agent Sandbox: lets the app create Linux guest VMs via Apple's
	     Virtualization.framework (VZVirtualMachine). Without this, VM start
	     fails with a missing-entitlement error and the sandbox can't boot.
	     Grantable for Developer ID + notarization AND compatible with the App
	     Sandbox / Mac App Store (UTM ships on the MAS with it). Only exercised
	     when the user turns the Agent Sandbox on in Settings; a normal launch
	     never touches VZ. -->
	<key>com.apple.security.virtualization</key>
	<true/>
</dict>
</plist>
